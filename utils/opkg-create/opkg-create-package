#!/bin/bash
# Usage: ./opkg-create-package DIR
#   Where DIR is directory where package template is stored
#  Output package is placed to current directory and is in format NAME.ipk where
#  NAME is package name from control file
set -e

# First argument can be path to package
[ -n "$1" ] && S="$1" || S=.
# Second argument can be path where package will be build
[ -n "$2" ] && O="$2" || O=.

NAME=`grep -E "^Package:" $S/control | sed 's/^Package:[ ]*//;s/[ ]*$//'`

# First generate files-md5sum file
mkdir -p $O/.control
(cd $S/data && find -type f | xargs md5sum) > $O/.control/files-md5sum

# now create control.tar.gz
add_control() {
	if [ -f $1 ]; then
		CTRFILES="$CTRFILES ./$1"
		cp $S/$1 $O/.control/$1
	fi
}
add_control conffiles
add_control preinst
add_control postinst
add_control prerm
add_control postrm
cp $S/control $O/.control/
tar -czf $O/control.tar.gz -C "$O/.control" ./control $CTRFILES ./files-md5sum
rm -rf $O/.control

# Package data
tar -czf $O/data.tar.gz -C $S/data $(cd $S/data && find -type f)

# create package
echo 2 > $O/debian-binary
tar -czf $O/$NAME.ipk -C "$O" ./debian-binary ./control.tar.gz ./data.tar.gz
rm $O/debian-binary
rm $O/control.tar.gz
rm $O/data.tar.gz
